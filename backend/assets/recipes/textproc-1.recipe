# Recipe for task 'textproc-1'
# v.0.2 -- 09.09.2025

DEFINE HOME /home/student/
DEFINE TASK_DIR %HOME%textproc-1/
DEFINE ORIGINAL_FILE %TASK_DIR%virus_tf.log
DEFINE BACKUP_DIR /tmp/bk/
DEFINE BACKUP_FILE %BACKUP_DIR%.virus_tf.log
DEFINE BACKUP_SHA1 %BACKUP_DIR%.sha1

CREATE_DIR %TASK_DIR%
CREATE_DIR %BACKUP_DIR%

SCRIPT
#!/usr/bin/python3
import os
import random
import sys
from datetime import datetime, timedelta

logs_dir = "/usr/share/course/logs-template/"
task_dir = "%TASK_DIR%"

def parse_selected_log_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            lines = [line.strip() for line in f.readlines() if line.strip()]
            return lines
    except IOError as e:
        raise IOError(f"Error reading {filepath}: {e}")

def generate_log_entry(base_time, delta_seconds, message):
    levels = ['INFO', 'DEBUG', 'WARN', 'ERROR']
    modules = ['AUTH', 'CORE', 'NET', 'SYS']

    log_time = (base_time + timedelta(seconds=delta_seconds)).strftime('%H:%M:%S')
    level = random.choice(levels)
    module = random.choice(modules)

    return f"[{level}] [{module}] [{log_time}] {message}"

def main():
    num_entries = 1000
    log_files = [f"{logs_dir}log{i}.txt" for i in range(1, 7)]
    output_file = f"{task_dir}virus_tf.log"

    if not any(os.path.isfile(f) for f in log_files):
        raise FileNotFoundError("No log files found in the directory")

    selected_file = None
    random.shuffle(log_files)
    for f in log_files:
        if os.path.isfile(f):
            selected_file = f
            break

    if not selected_file:
        raise FileNotFoundError("No valid log files found")

    try:
        lines = parse_selected_log_file(selected_file)
    except Exception as e:
        raise RuntimeError(f"Error processing {selected_file}: {e}")

    max_start = len(lines) - num_entries
    if max_start < 0:
        raise ValueError(f"File {selected_file} has only {len(lines)} lines, but {num_entries} requested")

    start_pos = random.randint(0, max_start)
    selected_lines = lines[start_pos:start_pos + num_entries]

    base_time = datetime.now()
    with open(output_file, 'w', encoding='utf-8') as f:
        for i, line in enumerate(selected_lines):
            log_entry = generate_log_entry(base_time, i, line)
            f.write(log_entry + '\n')

    print(f"Successfully generated {output_file} with {num_entries} entries from {selected_file}")

if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
END_SCRIPT

COPY %ORIGINAL_FILE% %BACKUP_FILE%
EXEC sha1sum %ORIGINAL_FILE% > %BACKUP_SHA1%
