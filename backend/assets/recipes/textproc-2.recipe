# Recipe for task 'textproc-2'
# v.0.2 -- 09.09.2025

DEFINE HOME /home/student/
DEFINE TASK_DIR %HOME%textproc-2/
DEFINE ORIGINAL_JSON %TASK_DIR%manifest.json
DEFINE BACKUP_DIR /tmp/bk/
DEFINE BACKUP_JSON %BACKUP_DIR%.manifest.json
DEFINE BACKUP_SHA1 %BACKUP_DIR%.sha1

CREATE_DIR %TASK_DIR%
CREATE_DIR %BACKUP_DIR%

# Script for creating random logs
SCRIPT
#!/usr/bin/python3
import random
import json
import yaml

task_dir = "%TASK_DIR%"

def generate_entries(count=1000):
    modules = ['core', 'net', 'auth', 'sys']
    statuses = ['active', 'inactive']
    priorities = random.sample(range(1, 1001), count)
    entries = []
    for i in range(count):
        module = random.choice(modules)
        number = random.randint(1, 100)
        entry = {
            'id': f"{module}.{number}",
            'status': random.choice(statuses),
            'priority': priorities[i]
        }
        entries.append(entry)
    return entries

def write_json_file(entries, filename=f'{task_dir}manifest.json'):
    with open(filename, 'w', encoding='utf-8') as f:
        json.dump(entries, f, indent=2)
        f.write('\n')

def write_yaml_file(entries, filename=f'{task_dir}manifest.yaml'):
    yaml_entries = []
    for entry in entries:
        yaml_entries.append({
            'id': entry['id'],
            'status': entry['status'],
            'priority': entry['priority']
        })
    with open(filename, 'w', encoding='utf-8') as f:
        yaml.dump(yaml_entries, f, default_flow_style=False, sort_keys=False)

def main():
    try:
        entries = generate_entries(1000)
        
        write_json_file(entries)
        print("Successfully generated manifest.json")
        
        write_yaml_file(entries)
        print("Successfully generated manifest.yaml")
        
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    import sys
    main()
END_SCRIPT

COPY %ORIGINAL_JSON% %BACKUP_JSON%
EXEC sha1sum %ORIGINAL_JSON% > %BACKUP_SHA1%
