# Recipe for task 'net-3'
# v.0.2 -- 09.09.2025

DEFINE HOME /home/student/
DEFINE TASK_DIR %HOME%net-3/

CREATE_DIR %TASK_DIR%

SCRIPT
#!/bin/bash

set -e
cd %TASK_DIR%
echo "Cleanup..."
docker-compose down 2>/dev/null || true
docker network rm net1 net2 2>/dev/null || true
sleep 5

echo "Creating docker-compose.yml..."
cat > %TASK_DIR%docker-compose.yml << 'EOF'
services:
  node-a:
    image: ubuntu:22.04
    container_name: node-a
    networks:
      net1:
    cap_add:
      - NET_ADMIN
    sysctls:
      - net.ipv4.ip_forward=0
    tty: true
    stdin_open: true
    command: /bin/bash -c "sleep infinity"

  node-b:
    image: ubuntu:22.04
    container_name: node-b
    networks:
      net1:
      net2:
    cap_add:
      - NET_ADMIN
    sysctls:
      - net.ipv4.ip_forward=1
    tty: true
    stdin_open: true
    command: /bin/bash -c "sleep infinity"

  node-c:
    image: ubuntu:22.04
    container_name: node-c
    networks:
      net2:
    cap_add:
      - NET_ADMIN
    sysctls:
      - net.ipv4.ip_forward=0
    tty: true
    stdin_open: true
    command: /bin/bash -c "sleep infinity"

networks:
  net1:
    driver: bridge
    ipam:
      config:
        - subnet: 10.0.1.0/24
  net2:
    driver: bridge
    ipam:
      config:
        - subnet: 10.0.2.0/24
EOF

echo "Starting containers..."
docker-compose up -d
sleep 5

echo "Installing required packages..."
install_packages() {
    local container=$1
    local packages=$2
    docker exec $container bash -c "apt update && apt install -y $packages"
}
install_packages node-a "iproute2 iptables iputils-ping traceroute"
install_packages node-b "iproute2 iptables iputils-ping"
install_packages node-c "iproute2 iptables iputils-ping"

echo "Configuring IP addresses..."
set_ip() {
    local container=$1
    local interface=$2
    local ip=$3
    docker exec $container ip link set $interface down
    docker exec $container ip addr flush dev $interface 2>/dev/null || true
    docker exec $container ip addr add $ip dev $interface
    docker exec $container ip link set $interface up
    sleep 5
}
set_ip node-a eth0 10.0.1.10/24
set_ip node-b eth0 10.0.1.1/24
set_ip node-b eth1 10.0.2.1/24
set_ip node-c eth0 10.0.2.20/24

END_SCRIPT
